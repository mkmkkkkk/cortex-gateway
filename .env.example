# Cortex Gateway — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# === Telegram Bot ===
CORTEX_TG_BOT_TOKEN=your-bot-token
CORTEX_TG_CHAT_ID=your-chat-id
CORTEX_TG_CEO_USER_ID=your-telegram-user-id

# === Cortex Worker ===
# Default: https://cortex.mkyang.ai/mcp (permanent, no tunnel needed)
# CC_MCP_URL=https://cortex.mkyang.ai/mcp

# === Agent HMAC Secrets ===
# One per agent. Format: GW_HMAC_{AGENT_ID_UPPERCASE}
# OC (owner, auto-approved):
GW_HMAC_OC=generate-with-secrets-token-hex-32

# Example external agents:
# GW_HMAC_BOB_AGENT=...
# GW_HMAC_ALICE_AGENT=...
