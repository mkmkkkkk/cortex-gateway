# Cortex Gateway — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# === Telegram (CEO control channel) ===
CORTEX_TG_BOT_TOKEN=           # @YourBot token from BotFather
CORTEX_TG_CHAT_ID=             # Target group/chat ID
CORTEX_TG_CEO_USER_ID=         # CEO's Telegram user_id (for per-user command auth)

# === CC Connection ===
CC_MCP_URL=                    # CC's Cloudflare Tunnel endpoint (auto-updated via /update-tunnel-url)
CORTEX_HMAC_SECRET_OC=         # Gateway → CC HMAC shared secret (must match CC side)
CC_TUNNEL_SECRET=              # Auth for /update-tunnel-url endpoint (must match CC side)

# === Gateway Identity ===
GW_CALLBACK_SECRET=            # CC → Gateway callback auth secret
GW_CALLBACK_URL=               # This gateway's callback URL (e.g., https://your-domain.com/callback)
GW_PUBLIC_URL=                 # Public-facing URL for onboard links (e.g., https://your-domain.com)

# === Agent HMAC Secrets (one per registered agent) ===
# Format: GW_HMAC_<AGENT_ID>=<hex_secret>
# Example:
# GW_HMAC_MY_AGENT=a1b2c3d4e5f6...
