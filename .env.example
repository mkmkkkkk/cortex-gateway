# Cortex Gateway — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# === Telegram Bot ===
CORTEX_TG_BOT_TOKEN=your-bot-token
CORTEX_TG_CHAT_ID=your-chat-id
CORTEX_TG_CEO_USER_ID=your-telegram-user-id

# === Cortex Worker (Gateway → Worker auth) ===
# Default URL: https://cortex.mkyang.ai/mcp (permanent, no tunnel needed)
# CC_MCP_URL=https://cortex.mkyang.ai/mcp
CORTEX_HMAC_SECRET_OC=generate-with-python-secrets-token-hex-32

# === Callback (CC → Gateway) ===
GW_CALLBACK_SECRET=generate-with-python-secrets-token-hex-32
GW_CALLBACK_URL=http://localhost:8750/callback

# === Inbound Agent HMAC Secrets (External agents → Gateway) ===
# One per agent. Format: GW_HMAC_{AGENT_ID_UPPERCASE}
# Referenced by agent-registry.json hmac_secret_env field.
GW_HMAC_OC=generate-with-python-secrets-token-hex-32

# Example external agents:
# GW_HMAC_BOB_AGENT=...
# GW_HMAC_ALICE_AGENT=...
