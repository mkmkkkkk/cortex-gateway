# Cortex Gateway — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
#
# ⚠️  Gateway will REFUSE TO START if required vars are missing.
#     Required: CC_TUNNEL_SECRET, CORTEX_HMAC_SECRET_OC, CORTEX_TG_BOT_TOKEN, CORTEX_TG_CHAT_ID

# === Telegram (CEO control channel) ===  [REQUIRED]
CORTEX_TG_BOT_TOKEN=           # @YourBot token from BotFather
CORTEX_TG_CHAT_ID=             # Target group/chat ID
CORTEX_TG_CEO_USER_ID=         # CEO's Telegram user_id (optional, for per-user command auth)

# === CC Connection ===  [REQUIRED]
CC_TUNNEL_SECRET=              # Shared secret for encrypted DNS tunnel URL sync (must match CC)
CORTEX_HMAC_SECRET_OC=         # Gateway → CC HMAC auth (must match CC's CORTEX_HMAC_SECRET_OC)
# CC_MCP_URL is auto-synced via DNS — do NOT set manually

# === Gateway Identity ===  (optional)
GW_CALLBACK_SECRET=            # CC → Gateway callback auth secret
GW_CALLBACK_URL=               # This gateway's callback URL
GW_PUBLIC_URL=                 # Public-facing URL for onboard links

# === Agent HMAC Secrets (one per registered agent) ===
# Format: GW_HMAC_<AGENT_ID>=<hex_secret>
# Example:
# GW_HMAC_MY_AGENT=a1b2c3d4e5f6...
